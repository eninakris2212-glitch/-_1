# Явные ожидания
import time
from selenium import webdriver
from selenium.webdriver.common.by import By
from selenium.webdriver.support.ui import WebDriverWait
from selenium.webdriver.support import expected_conditions as EC

def test_names_and_descriptions():
    # Инициализация драйвера
    driver = webdriver.Chrome()
    driver.maximize_window()

    # Переход на страницу всех питомцев
    driver.get("https://petfriends.skillfactory.ru/all_pets")

    # Явное ожидание загрузки имён и описаний
    names = WebDriverWait(driver, 10).until(
        EC.presence_of_all_elements_located((By.CSS_SELECTOR, ".table td:nth-child(2)"))
    )
    descriptions = WebDriverWait(driver, 10).until(
        EC.presence_of_all_elements_located((By.CSS_SELECTOR, ".table td:nth-child(3)"))
    )

    # Проверка наличия имён и описаний
    assert len(names) > 0, "Имена питомцев не найдены!"
    assert len(descriptions) > 0, "Описания питомцев не найдены!"

    # Закрытие браузера
    driver.quit()
